# Database (REQUIRED)
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=cuentas_claras

# Redis (REQUIRED)
REDIS_PASSWORD=your_redis_password_here

# Backend
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# reCAPTCHA v3 (optional but recommended for production)
# Get keys from: https://www.google.com/recaptcha/admin
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key
RECAPTCHA_ENABLED=false
RECAPTCHA_MIN_SCORE=0.5

# Frontend
VITE_API_URL=http://localhost:3000
VITE_WS_URL=ws://localhost:3000
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key

# =====================================================
# RAILWAY DEPLOYMENT NOTES:
# =====================================================
# Railway provides these automatically when you add services:
# - DATABASE_URL (PostgreSQL)
# - REDIS_URL (Redis with password included)
# 
# You only need to set manually:
# - CORS_ORIGIN (your frontend URL)
# - RECAPTCHA_SECRET_KEY (if using reCAPTCHA)
# - RECAPTCHA_ENABLED=true (to enable reCAPTCHA)
# - VITE_RECAPTCHA_SITE_KEY (in frontend service)
