generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Plan de gastos (sesión compartible)
model Plan {
  id          String   @id @default(cuid())
  code        String   @unique @db.VarChar(14) // Código XXXX-XXXX-XXXX (14 chars)
  name        String   @db.VarChar(100)
  description String?  @db.VarChar(500)
  currency    String   @default("COP") @db.VarChar(3) // COP, USD, EUR, etc.
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  closedAt    DateTime? // Cuando se cierra el plan
  
  participants Participant[]
  expenses     Expense[]
  history      HistoryEntry[]
  
  @@index([code])
  @@index([createdAt])
}

// Participante de un plan
model Participant {
  id            String   @id @default(cuid())
  planId        String
  plan          Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  name          String   @db.VarChar(50)
  avatarSeed    String?  @db.VarChar(20) // Seed para Multiavatar
  paymentLink   String?  @db.VarChar(500) // Link de Nequi/Daviplata/etc
  multiplier    Int      @default(1) // Paga por cuántas personas
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  expenses      Expense[]
  
  @@unique([planId, name])
  @@index([planId])
}

// Gasto individual
model Expense {
  id            String      @id @default(cuid())
  planId        String
  plan          Plan        @relation(fields: [planId], references: [id], onDelete: Cascade)
  participantId String
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  amount        Decimal     @db.Decimal(12, 2)
  description   String?     @db.VarChar(200)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  @@index([planId])
  @@index([participantId])
  @@index([createdAt])
}

// Historial de cambios para auditoría
model HistoryEntry {
  id        String   @id @default(cuid())
  planId    String
  plan      Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)
  action    String   @db.VarChar(50) // CREATE_EXPENSE, UPDATE_PARTICIPANT, etc
  entityType String  @db.VarChar(50) // EXPENSE, PARTICIPANT, PLAN
  entityId  String
  oldData   Json?    // Estado anterior
  newData   Json?    // Estado nuevo
  createdAt DateTime @default(now())
  
  @@index([planId])
  @@index([createdAt])
  @@index([entityType, entityId])
}
